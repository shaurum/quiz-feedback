# Google Gemini API ключ
# Получить: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_api_key_here

# Google Apps Script URL для отправки данных в таблицу
# Санкт-Петербург
GOOGLE_APPS_SCRIPT_URL_SPB=your_spb_google_apps_script_url_here

# Москва
GOOGLE_APPS_SCRIPT_URL_MSK=your_msk_google_apps_script_url_here

# Yandex Cloud (опционально, для YandexGPT)
YC_OAUTH_TOKEN=
YC_CLOUD_ID=
YC_FOLDER_ID=
